\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Evolutionary trajectories at $M = N = 11$ ($T = 50$, $K = 500$, $30$ replicates averaged). (a)\nobreakspace  {}Full-veridical fraction over 5000 generations. Only families with $\delta _\mu $ above the mutation-selection threshold (\texttt  {gauss\_iso}, \texttt  {gauss\_k10}) achieve substantial veridicality; others stall near zero. (b)\nobreakspace  {}Mean Bayes risk over generations. All families converge to low risk ($0.01$--$0.05$), but the most veridical family (\texttt  {gauss\_iso}, blue) has the \emph  {highest} asymptotic risk. See text for the explanation via \cref  {thm:veridicality}(c).\relax }}{30}{figure.caption.16}\protected@file@percent }
\newlabel{fig:family-trajectories}{{8}{30}{Evolutionary trajectories at $M = N = 11$ ($T = 50$, $K = 500$, $30$ replicates averaged). (a)~Full-veridical fraction over 5000 generations. Only families with $\dmu $ above the mutation-selection threshold (\texttt {gauss\_iso}, \texttt {gauss\_k10}) achieve substantial veridicality; others stall near zero. (b)~Mean Bayes risk over generations. All families converge to low risk ($0.01$--$0.05$), but the most veridical family (\texttt {gauss\_iso}, blue) has the \emph {highest} asymptotic risk. See text for the explanation via \cref {thm:veridicality}(c).\relax }{figure.caption.16}{}}
