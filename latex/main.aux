\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Numerical illustration of \cref  {thm:quasispecies} and \cref  {rem:periodic}. \textbf  {(A)}\nobreakspace  {}Constrained mutation with two closed classes ($\mathcal  {K}_1$ dominant, $\mathcal  {K}_2$ subdominant) and one transient state. From the transient state (reachable to both classes), mean risk drops to the dominant-class asymptote $R^*_{\mathcal  {K}_1}$; from initial support restricted to $\mathcal  {K}_2$, the population is trapped at $R^*_{\mathcal  {K}_2}$. Dashed lines: theoretical asymptotic risk from Perron eigenvectors of each block. \textbf  {(B)}\nobreakspace  {}Quotient dynamics for the accessible case: mass on $\mathcal  {K}_1$ (dominant) grows monotonically while $\mathcal  {K}_2$ and the transient set are driven to zero, consistent with the spectral-radius ordering $\lambda _{\mathcal  {K}_1} > \lambda _{\mathcal  {K}_2}$. \textbf  {(C)}\nobreakspace  {}Irreducible period-2 mutation (\cref  {rem:periodic}): the raw trajectory oscillates indefinitely, but the Ces\`aro mean converges to the Perron profile (dashed).\relax }}{35}{figure.caption.18}\protected@file@percent }
\newlabel{fig:theorem-dynamics}{{9}{35}{Numerical illustration of \cref {thm:quasispecies} and \cref {rem:periodic}. \textbf {(A)}~Constrained mutation with two closed classes ($\mathcal {K}_1$ dominant, $\mathcal {K}_2$ subdominant) and one transient state. From the transient state (reachable to both classes), mean risk drops to the dominant-class asymptote $R^*_{\mathcal {K}_1}$; from initial support restricted to $\mathcal {K}_2$, the population is trapped at $R^*_{\mathcal {K}_2}$. Dashed lines: theoretical asymptotic risk from Perron eigenvectors of each block. \textbf {(B)}~Quotient dynamics for the accessible case: mass on $\mathcal {K}_1$ (dominant) grows monotonically while $\mathcal {K}_2$ and the transient set are driven to zero, consistent with the spectral-radius ordering $\lambda _{\mathcal {K}_1} > \lambda _{\mathcal {K}_2}$. \textbf {(C)}~Irreducible period-2 mutation (\cref {rem:periodic}): the raw trajectory oscillates indefinitely, but the Ces\`aro mean converges to the Perron profile (dashed).\relax }{figure.caption.18}{}}
\newlabel{fig:theorem-dynamics@cref}{{[figure][9][]9}{[1][34][]35}}
