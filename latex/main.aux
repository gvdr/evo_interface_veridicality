\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Distribution of all $55$ pairwise task distances $\sigma ^2(w_i, w_j)$ for each task family (population estimates from $10{,}000$ task samples). Dashed horizontal lines mark $\delta _\mu $ (the minimum, i.e.\ the bottleneck pair). The dotted line marks the approximate mutation-selection threshold $\delta _\mu ^* \approx 2C\varepsilon /\pi _{\qopname  \relax m{min}}^2$: pairs above this line can be maintained by selection against the mutation load; pairs below it cannot. Only \texttt  {gauss\_iso} has \emph  {all} pairs above the threshold.\relax }}{20}{figure.caption.8}\protected@file@percent }
\newlabel{fig:sigma2-dist}{{3}{20}{Distribution of all $55$ pairwise task distances $\sigmasq (w_i, w_j)$ for each task family (population estimates from $10{,}000$ task samples). Dashed horizontal lines mark $\dmu $ (the minimum, i.e.\ the bottleneck pair). The dotted line marks the approximate mutation-selection threshold $\dmu ^* \approx 2C\varepsilon /\pimin ^2$: pairs above this line can be maintained by selection against the mutation load; pairs below it cannot. Only \texttt {gauss\_iso} has \emph {all} pairs above the threshold.\relax }{figure.caption.8}{}}
\newlabel{fig:sigma2-dist@cref}{{[figure][3][]3}{[1][19][]20}}
\@writefile{toc}{\contentsline {paragraph}{From distance structure to final outcomes.}{20}{section*.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces (a)\nobreakspace  {}Final full-veridical fraction versus population $\delta _\mu $ (log scale). Large markers: family means across all $T$ and replicates; small points: individual runs. The monotone trend confirms that the bottleneck distance controls veridicality. (b)\nobreakspace  {}Mean Bayes risk versus population $\delta _\mu $. Risk is nearly flat across families, and if anything, \emph  {higher} for the most veridical family, because ill-conditioned ecologies permit low-risk non-veridical encodings that merge near-indistinguishable states.\relax }}{21}{figure.caption.10}\protected@file@percent }
\newlabel{fig:veridicality-delta}{{4}{21}{(a)~Final full-veridical fraction versus population $\dmu $ (log scale). Large markers: family means across all $T$ and replicates; small points: individual runs. The monotone trend confirms that the bottleneck distance controls veridicality. (b)~Mean Bayes risk versus population $\dmu $. Risk is nearly flat across families, and if anything, \emph {higher} for the most veridical family, because ill-conditioned ecologies permit low-risk non-veridical encodings that merge near-indistinguishable states.\relax }{figure.caption.10}{}}
\newlabel{fig:veridicality-delta@cref}{{[figure][4][]4}{[1][20][]21}}
