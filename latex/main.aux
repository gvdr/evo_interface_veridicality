\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Mean Bayes risk over 5000 generations for representative task counts ($T = 1, 10, 100, 1000$) in the Berke-style setting ($N=11$, $M=2$). All trajectories decline, confirming \cref  {thm:price-risk}. They converge to approximately the same asymptotic value, the $M=2$ capacity floor (\cref  {thm:lossy}), since the optimal $2$-cell partition is the same regardless of $T$. Higher $T$ reduces per-generation sampling noise but does not change the asymptotic level in this model.\relax }}{29}{figure.caption.15}\protected@file@percent }
\newlabel{fig:risk-trajectories}{{7}{29}{Mean Bayes risk over 5000 generations for representative task counts ($T = 1, 10, 100, 1000$) in the Berke-style setting ($N=11$, $M=2$). All trajectories decline, confirming \cref {thm:price-risk}. They converge to approximately the same asymptotic value, the $M=2$ capacity floor (\cref {thm:lossy}), since the optimal $2$-cell partition is the same regardless of $T$. Higher $T$ reduces per-generation sampling noise but does not change the asymptotic level in this model.\relax }{figure.caption.15}{}}
\newlabel{fig:risk-trajectories@cref}{{[figure][7][]7}{[1][29][]29}}
